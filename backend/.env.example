# Brand Intel Monitoring Daemon Configuration
# Copy this file to .env and update with your values

# ============================================================================
# REQUIRED
# ============================================================================

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017

# OpenAI API key for AI enrichment (set ENRICHMENT_ENABLED=false to disable)
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.3

# ============================================================================
# MONITOR API KEYS
# ============================================================================

# GitHub personal access token (free - increases rate limits)
GITHUB_TOKEN=

# Intelligence X API key (free tier - signup at intelx.io)
# Get from: https://intelx.io/account?tab=developer
INTELX_API_KEY=

# Note: HackerNews, Ransomware.live, and XposedOrNot monitors are FREE
# and require no API keys. They work out of the box.

# ============================================================================
# SCHEDULING & PERFORMANCE
# ============================================================================

# Scan interval in minutes (1-1440)
SCAN_INTERVAL_MINUTES=15

# Max brands to scan concurrently (1-100)
MAX_CONCURRENT_BRANDS=10

# Max monitors to run per brand (1-10)
MAX_CONCURRENT_MONITORS=4

# Monitor timeout in seconds (5-300)
MONITOR_TIMEOUT_SECONDS=30

# Retry settings
MAX_RETRIES=3
RETRY_BASE_DELAY=1.0
RETRY_MAX_DELAY=60.0

# Rate limits (requests per minute)
GITHUB_RATE_LIMIT=30

# ============================================================================
# OPTIONAL FEATURES
# ============================================================================

# AI Enrichment
ENRICHMENT_ENABLED=true
USE_ANTHROPIC=false
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-3-haiku-20240307
ANTHROPIC_TEMPERATURE=0.3

# Circuit Breaker
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_SECONDS=300

# Dead Letter Queue
DLQ_ENABLED=true
DLQ_MAX_RETRIES=3

# Alerting (Slack webhook or email)
SLACK_WEBHOOK_URL=
ALERT_EMAIL=
ALERT_ON_MONITOR_FAILURE=true
ALERT_FAILURE_THRESHOLD=3

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PORT=8001

# Logging
LOG_LEVEL=INFO
