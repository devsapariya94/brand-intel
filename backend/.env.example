# Brand Intel Monitoring Daemon Configuration
# Copy this file to .env and update with your values

# ============================================================================
# REQUIRED CONFIGURATION
# ============================================================================

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017

# ============================================================================
# SCHEDULING CONFIGURATION
# ============================================================================

# Interval between scans in minutes (1-1440)
SCAN_INTERVAL_MINUTES=15

# Maximum number of brands to scan concurrently (1-100)
MAX_CONCURRENT_BRANDS=10

# Maximum number of monitors to run per brand (1-10)
MAX_CONCURRENT_MONITORS=4

# ============================================================================
# MONITOR RATE LIMITS (requests per minute)
# ============================================================================

PASTEBIN_RATE_LIMIT=60
GITHUB_RATE_LIMIT=30
REDDIT_RATE_LIMIT=60
HIBP_RATE_LIMIT=60

# ============================================================================
# TIMEOUT & RETRY CONFIGURATION
# ============================================================================

# Monitor timeout in seconds (5-300)
MONITOR_TIMEOUT_SECONDS=30

# Maximum retry attempts (0-10)
MAX_RETRIES=3

# Base delay between retries in seconds (0.1-60.0)
RETRY_BASE_DELAY=1.0

# Maximum delay between retries in seconds (1.0-300.0)
RETRY_MAX_DELAY=60.0

# ============================================================================
# CIRCUIT BREAKER CONFIGURATION
# ============================================================================

# Enable circuit breaker pattern (true/false)
CIRCUIT_BREAKER_ENABLED=true

# Number of failures before opening circuit (1-20)
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# Timeout before retrying in seconds (60-3600)
CIRCUIT_BREAKER_TIMEOUT_SECONDS=300

# ============================================================================
# ALERTING CONFIGURATION
# ============================================================================

# Slack webhook URL for alerts (optional)
# Get from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Email address for critical alerts (optional)
ALERT_EMAIL=

# Send alerts when monitors fail (true/false)
ALERT_ON_MONITOR_FAILURE=true

# Number of consecutive failures before alerting (1-10)
ALERT_FAILURE_THRESHOLD=3

# ============================================================================
# HEALTH CHECK CONFIGURATION
# ============================================================================

# Enable health check HTTP endpoint (true/false)
HEALTH_CHECK_ENABLED=true

# Port for health check endpoint (1024-65535)
HEALTH_CHECK_PORT=8001

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format string
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ============================================================================
# DEAD LETTER QUEUE CONFIGURATION
# ============================================================================

# Enable dead letter queue for failed hits (true/false)
DLQ_ENABLED=true

# Maximum retry attempts for DLQ items (0-10)
DLQ_MAX_RETRIES=3
# ============================================================================
# AI ENRICHMENT CONFIGURATION
# ============================================================================

# Enable AI enrichment layer (true/false)
ENRICHMENT_ENABLED=true

# Use Anthropic native API (true/false)
# If true: uses ANTHROPIC_API_KEY and ANTHROPIC_MODEL
# If false: uses LLM_API_KEY, LLM_BASE_URL, LLM_MODEL (OpenAI-spec compatible)
USE_ANTHROPIC=false

# Generic LLM Configuration (OpenAI-Spec Compatible)
# Works with: OpenAI, Ollama, OpenRouter, Gemini, Azure, etc.
# OpenAI:     LLM_BASE_URL=https://api.openai.com/v1
# Ollama:     LLM_BASE_URL=http://localhost:11434/v1
# OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1
# Gemini:     LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.3

# Anthropic Configuration (only used when USE_ANTHROPIC=true)
# Get API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-3-haiku-20240307
ANTHROPIC_TEMPERATURE=0.3

# Processing Configuration
# Number of hits to process in each batch (1-50)
ENRICHMENT_BATCH_SIZE=10

# Seconds between batch processing runs (10-300)
ENRICHMENT_INTERVAL=30

# Maximum concurrent LLM API calls (1-20)
ENRICHMENT_CONCURRENCY=5

# Decision Thresholds
# High confidence threshold for auto-alert (0.0-1.0)
HIGH_CONFIDENCE_THRESHOLD=0.85

# Medium confidence threshold (0.0-1.0)
MEDIUM_CONFIDENCE_THRESHOLD=0.70

# Escalation threshold - below this goes to human review (0.0-1.0)
ESCALATE_CONFIDENCE_THRESHOLD=0.60

# Cost Controls
# Maximum daily cost in USD (0.0-1000.0)
MAX_DAILY_COST_USD=10.0

# Error Handling
# Queue for review on AI failure instead of sending alert (true/false)
ENRICHMENT_FAIL_CLOSED=true

# Maximum retry attempts for enrichment (0-5)
ENRICHMENT_MAX_RETRIES=2


# ============================================================================
# MONITOR API KEYS (if required by specific monitors)
# ============================================================================

# Pastebin API key (optional)
PASTEBIN_API_KEY=

# GitHub personal access token (optional, increases rate limits)
GITHUB_TOKEN=

# Reddit API credentials (optional)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Have I Been Pwned API key (optional)
HIBP_API_KEY=